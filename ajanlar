# 1. Haber Bulma Ajanı Fonksiyonu
def haber_akilli_filtrele(tarih, haberGorev):
    prompt = f"""
    Tarih: {tarih}
    {haberGorev}
    """
    response = client.models.generate_content(
    model='gemini-2.5-flash',
    contents=prompt,
    config=configGazeteci   
    )
    return response.text

